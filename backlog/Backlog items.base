filters:
  and:
    - file.inFolder("backlog/items")
properties:
  id:
    displayName: "#"
  type:
    displayName: Type
  priority:
    displayName: Pri
views:
  - type: table
    name: All items
    order:
      - priority
      - id
      - file.name
      - type
      - status
      - epic
    sort:
      - property: priority
        direction: DESC
    columnSize:
      note.priority: 99
      note.id: 50
      file.name: 400
      note.type: 120
  - type: table
    name: Open items
    filters:
      or:
        - status == "open"
        - status == "active"
    order:
      - priority
      - id
      - file.name
      - type
      - status
      - epic
      - tags
    sort:
      - property: priority
        direction: DESC
    columnSize:
      note.priority: 103
      note.id: 50
      file.name: 400
      note.type: 120
  - type: cards
    name: Board
    groupBy:
      property: status
      direction: ASC
    order:
      - priority
      - file.name
      - type
      - epic
  - type: table
    name: Imported
    filters:
      and:
        - status != "done"
        - tags.contains("imported")
    order:
      - priority
      - id
      - file.name
      - type
      - status
      - epic
      - tags
    columnSize:
      note.priority: 111
      note.id: 50
      file.name: 400
      note.type: 120
  - type: table
    name: By epic
    filters:
      and:
        - |
          !status.containsAny("done","closed")
    groupBy:
      property: epic
      direction: ASC
    order:
      - priority
      - id
      - file.name
      - type
      - status
      - tags
    sort:
      - property: status
        direction: ASC
      - property: priority
        direction: DESC
    columnSize:
      note.priority: 99
      note.id: 50
      file.name: 400
      note.type: 120
